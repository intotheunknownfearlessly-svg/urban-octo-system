import { exec } from "child_process";

export function deployToRepo(repo: string) {
  return new Promise((resolve, reject) => {
    exec(`git push https://github.com/${repo}`, (err, stdout) => {
      if (err) reject(err);
      else resolve(stdout);
    });
  });
}
