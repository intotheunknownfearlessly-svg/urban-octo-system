// src/core/launch/engine.ts
import { runLLM } from "@/integrations/llm/provider";
import { saveMemory } from "@/core/memory/store";

export async function runLaunchPipeline(objective: string) {
  const market = await runLLM(`Define ICP + market framing for: ${objective}`);
  const offer = await runLLM(`Create irresistible offer for: ${objective}`);
  const copy = await runLLM(`Write high-converting landing page copy`);

